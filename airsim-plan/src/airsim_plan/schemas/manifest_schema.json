{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lm-drone.local/schemas/manifest.schema.json",
  "title": "MissionManifest",
  "type": "object",
  "required": ["mission_id", "waypoints", "rules_of_engagement"],
  "additionalProperties": false,
  "properties": {
    "mission_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_]{3,32}$",
      "description": "Uppercase identifier for the mission (e.g. PERIMETER_NORTH_01)."
    },
    "summary": {
      "type": "string",
      "description": "Human-readable one-line description."
    },
    "waypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["x", "y", "z"],
        "additionalProperties": false,
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"},
          "z": {"type": "number"},
          "label": {"type": "string"}
        }
      }
    },
    "rules_of_engagement": {
      "type": "object",
      "required": [
        "ignore_objects",
        "return_to_launch_battery_threshold"
      ],
      "additionalProperties": false,
      "properties": {
        "ignore_objects": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Object classes the tactical SLM must treat as non-hostile."
        },
        "return_to_launch_battery_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 100.0
        },
        "max_speed_mps": {"type": "number", "minimum": 0.0},
        "min_altitude_m": {"type": "number"},
        "notes": {"type": "string"}
      }
    },
    "tactical_system_prompt": {
      "type": "string",
      "description": "Pre-prompt handed to the LangGraph SLM (Step 3)."
    }
  }
}
