# LM Studio (or any OpenAI-compatible) local server for the Mission Planner.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=llama-3-8b-instruct

# Tactical SLM (Phi-3) served the same way. Kept separate so you can swap models.
TACTICAL_BASE_URL=http://localhost:1234/v1
TACTICAL_API_KEY=lm-studio
TACTICAL_MODEL=phi-3-mini-4k-instruct

# AirSim
AIRSIM_HOST=127.0.0.1
AIRSIM_VEHICLE_NAME=Drone0

# Mission defaults
DEFAULT_TAKEOFF_ALT=-10.0
DEFAULT_SPEED=5.0
