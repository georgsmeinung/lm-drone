# IP address of the machine running the AirSim / Unreal Engine simulator.
# If the simulator is running on the same machine, use 127.0.0.1.
# If running on a different machine (e.g., Windows PC while running Python on Mac),
# use the local IP address of that machine (e.g., 192.168.1.100).
AIRSIM_IP="192.168.110.110"
